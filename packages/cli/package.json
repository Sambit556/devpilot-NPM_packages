{
  "name": "@devspilot/cli",
  "version": "0.0.1",
  "description": "DevsPilot CLI — The Developer Operating System",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "devspilot": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@devspilot/core": "workspace:*",
    "@devspilot/shared": "workspace:*",
    "picocolors": "^1.0.0",
    "cli-table3": "^0.6.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}